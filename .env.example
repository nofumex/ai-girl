# --- Telegram (required) ---
API_ID=123456
API_HASH=your_api_hash_here
SESSION_NAME=ai_girl_session
# Optional: use StringSession instead of a .session file
# SESSION_STRING=

OWNER_ID=123456789

# --- LLM keys (set all you have; fallback order is fixed: Gemini → Groq → Cerebras → SiliconFlow) ---
GEMINI_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
SILICONFLOW_API_KEY=

# Optional: proxy for LLM requests (format: http://user:pass@host:port)
# LLM_PROXY=http://smartyou777:tztBWMSDcn@91.147.119.175:50101

# Optional model overrides (LiteLLM provider/model ids)
# MODEL_GEMINI=gemini/gemini-2.0-flash
# MODEL_GROQ=groq/llama-3.3-70b-versatile
# MODEL_CEREBRAS=cerebras/llama-3.3-70b
# MODEL_SILICONFLOW=siliconflow/Qwen/Qwen2.5-7B-Instruct

# --- Behavior ---
AUTO_START_ENABLED=true
REPLY_IN_GROUPS=true
IGNORE_BOTS=true
GHOST_MODE_DEFAULT=false
ENABLE_OWNER_ASK=true

HISTORY_MIN_MESSAGES=8
HISTORY_MAX_MESSAGES=15

COOLDOWN_SECONDS_AI=2
COOLDOWN_SECONDS_STATIC=300
COOLDOWN_SECONDS_STATIC_VIP=60

# Debounce: wait after last user message before one LLM call (same chat + same sender)
DEBOUNCE_SECONDS_MIN=1.5
DEBOUNCE_SECONDS_MAX=3.0

# Pause between consecutive outgoing bubbles in the same reply turn
BOT_BURST_PAUSE_MIN=0.8
BOT_BURST_PAUSE_MAX=1.5

READ_DELAY_MIN=1.2
READ_DELAY_MAX=3.8
TYPING_PER_CHAR_MIN=0.08
TYPING_PER_CHAR_MAX=0.13
EXTRA_PAUSE_PROBABILITY=0.22
EXTRA_PAUSE_MIN=0.4
EXTRA_PAUSE_MAX=1.6
SPLIT_MESSAGE_PROBABILITY=0.28

TYPO_MESSAGE_PROBABILITY=0.12
REACTION_PROBABILITY=0.18

LOG_LEVEL=INFO

API_RESTART_BASE_DELAY=5
API_RESTART_MAX_DELAY=120
